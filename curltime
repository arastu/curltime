#!/usr/bin/env bash
# curltime — observe timings for a curl request, with optional ping-like repeat.
# Pure bash + awk. Works with any curl >= 7.19.

set -u

VERSION="2.0.0"

# ---------- curl detection ----------
pick_curl() {
  if [ -n "${CURLTIME_CURL:-}" ] && [ -x "${CURLTIME_CURL}" ]; then
    echo "$CURLTIME_CURL"; return
  fi
  local c
  c="$(command -v curl 2>/dev/null)"
  if [ -n "$c" ] && [ -x "$c" ]; then echo "$c"; return; fi
  if [ -x /usr/bin/curl ]; then echo /usr/bin/curl; return; fi
  echo ""; return 1
}
CURL_BIN="$(pick_curl)"
if [ -z "$CURL_BIN" ]; then
  echo "curltime: no curl binary found" >&2
  exit 127
fi

# ---------- colors ----------
if [ -t 1 ] && [ "${NO_COLOR:-}" = "" ]; then
  C_RESET=$'\033[0m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'
  C_CYAN=$'\033[36m';  C_GREEN=$'\033[32m'; C_YEL=$'\033[33m'
  C_RED=$'\033[31m';   C_MAG=$'\033[35m';   C_BLUE=$'\033[34m'
  C_GREY=$'\033[90m'
else
  C_RESET=""; C_DIM=""; C_BOLD=""; C_CYAN=""; C_GREEN=""; C_YEL=""; C_RED=""; C_MAG=""; C_BLUE=""; C_GREY=""
fi

usage() {
  cat <<EOF
${C_BOLD}curltime${C_RESET} v${VERSION} — visualise curl request timings

${C_BOLD}USAGE${C_RESET}
  curltime [curltime-options] [curl-options] <url>

${C_BOLD}CURLTIME OPTIONS${C_RESET}
  -n, --count <N>       Run N requests (ping-like). 0 = infinite. Default: 1
  -i, --interval <SEC>  Delay between requests. Default: 1
  -t, --continuous      Same as --count 0
      --no-color        Disable colour output
      --curl <PATH>     Use a specific curl binary
      --version         Show version
  -h, --help            Show this help

Anything else is passed straight through to curl, so you can use it just
like curl: ${C_DIM}curltime -X POST -H 'x: y' -d '...' https://api/...${C_RESET}

${C_BOLD}ENVIRONMENT${C_RESET}
  CURLTIME_CURL        Override curl binary (same as --curl)
  NO_COLOR         Disable colour output

${C_BOLD}EXAMPLES${C_RESET}
  curltime https://google.com
  curltime -n 10 -i 0.5 https://api.example.com/health
  curltime -t https://example.com           # run until Ctrl+C
  curltime -H 'Authorization: Bearer x' https://api/me
EOF
}

# ---------- arg parsing (split curltime flags from curl flags) ----------
COUNT=1
INTERVAL=1
CURL_ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    -n|--count)        COUNT="${2:?}"; shift 2 ;;
    -i|--interval)     INTERVAL="${2:?}"; shift 2 ;;
    -t|--continuous)   COUNT=0; shift ;;
    --no-color)        C_RESET=""; C_DIM=""; C_BOLD=""; C_CYAN=""; C_GREEN=""; C_YEL=""; C_RED=""; C_MAG=""; C_BLUE=""; C_GREY=""; shift ;;
    --curl)            CURL_BIN="${2:?}"; shift 2 ;;
    --version)         echo "curltime $VERSION"; exit 0 ;;
    -h|--help)         usage; exit 0 ;;
    --)                shift; CURL_ARGS+=("$@"); break ;;
    *)                 CURL_ARGS+=("$1"); shift ;;
  esac
done

if [ ${#CURL_ARGS[@]} -eq 0 ]; then
  usage; exit 1
fi

# ---------- write-out format ----------
# Pipe-separated for safe parsing.
WRITE_OUT='%{http_code}|%{time_namelookup}|%{time_connect}|%{time_appconnect}|%{time_pretransfer}|%{time_starttransfer}|%{time_total}|%{size_download}|%{speed_download}|%{remote_ip}'

# Try to surface the request URL for the header line.
URL=""
prev=""
for a in "${CURL_ARGS[@]}"; do
  case "$a" in
    http://*|https://*) URL="$a" ;;
    --url) prev="--url" ;;
    *)
      if [ "$prev" = "--url" ]; then URL="$a"; prev=""; fi
      ;;
  esac
done
[ -z "$URL" ] && URL="(request)"

# ---------- helpers ----------
fmt_ms() { awk -v s="$1" 'BEGIN{printf "%.1f", s*1000}'; }
sub_ms() { awk -v a="$1" -v b="$2" 'BEGIN{ r=(a-b)*1000; if (r<0) r=0; printf "%.1f", r }'; }
fmt_bytes() {
  awk -v b="$1" 'BEGIN{
    split("B KB MB GB", u);
    i=1; while (b>=1024 && i<4) { b/=1024; i++ }
    printf (i==1?"%d %s":"%.1f %s"), b, u[i]
  }'
}
bar() { # bar <value_ms> <max_ms> <width>
  awk -v v="$1" -v m="$2" -v w="$3" 'BEGIN{
    if (m<=0) { for(i=0;i<w;i++) printf " "; exit }
    n = int((v/m)*w + 0.5); if (n>w) n=w
    for (i=0;i<n;i++) printf "█"
    for (i=n;i<w;i++) printf "░"
  }'
}
status_color() {
  case "${1:0:1}" in
    2) printf "%s" "$C_GREEN" ;;
    3) printf "%s" "$C_CYAN" ;;
    4) printf "%s" "$C_YEL" ;;
    5) printf "%s" "$C_RED" ;;
    *) printf "%s" "$C_RED" ;;
  esac
}

# ---------- single-run pretty output ----------
print_single() {
  local raw="$1"
  IFS='|' read -r code t_dns t_con t_app t_pre t_ttfb t_total size speed ip <<<"$raw"

  local ms_dns ms_con ms_tls ms_pre ms_ttfb ms_xfer ms_total
  ms_dns=$(fmt_ms "$t_dns")
  ms_con=$(sub_ms "$t_con" "$t_dns")
  if awk -v a="$t_app" 'BEGIN{exit !(a>0)}'; then
    ms_tls=$(sub_ms "$t_app" "$t_con")
    ms_pre=$(sub_ms "$t_pre" "$t_app")
  else
    ms_tls="0.0"
    ms_pre=$(sub_ms "$t_pre" "$t_con")
  fi
  ms_ttfb=$(sub_ms "$t_ttfb" "$t_pre")
  ms_xfer=$(sub_ms "$t_total" "$t_ttfb")
  ms_total=$(fmt_ms "$t_total")

  # max for bar scaling
  local maxv
  maxv=$(printf "%s\n" "$ms_dns" "$ms_con" "$ms_tls" "$ms_pre" "$ms_ttfb" "$ms_xfer" \
    | awk 'BEGIN{m=0} {v=$1+0; if (v>m) m=v} END{if (m<=0) m=1; print m}')

  local sc; sc="$(status_color "$code")"
  printf "\n  ${C_BOLD}curltime${C_RESET} ${C_DIM}→${C_RESET} ${C_CYAN}%s${C_RESET}" "$URL"
  [ -n "$ip" ] && printf " ${C_DIM}(%s)${C_RESET}" "$ip"
  printf "\n  ${C_GREY}────────────────────────────────────────────────────────────${C_RESET}\n"
  printf "  ${C_MAG}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "DNS lookup"        "$ms_dns"  "$(bar "$ms_dns"  "$maxv" 20)"
  printf "  ${C_BLUE}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "TCP connect"       "$ms_con"  "$(bar "$ms_con"  "$maxv" 20)"
  printf "  ${C_YEL}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "TLS handshake"     "$ms_tls"  "$(bar "$ms_tls"  "$maxv" 20)"
  printf "  ${C_CYAN}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "Pre-transfer"      "$ms_pre"  "$(bar "$ms_pre"  "$maxv" 20)"
  printf "  ${C_GREEN}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "Server processing" "$ms_ttfb" "$(bar "$ms_ttfb" "$maxv" 20)"
  printf "  ${C_RED}●${C_RESET} %-18s ${C_BOLD}%7s ms${C_RESET}  ${C_GREY}%s${C_RESET}\n" "Content transfer"  "$ms_xfer" "$(bar "$ms_xfer" "$maxv" 20)"
  printf "  ${C_GREY}────────────────────────────────────────────────────────────${C_RESET}\n"
  printf "  ${C_BOLD}Total${C_RESET} %-14s ${C_BOLD}%7s ms${C_RESET}  ${sc}HTTP %s${C_RESET}" "" "$ms_total" "${code:-???}"
  if [ "${size:-0}" != "0" ]; then
    printf "   ${C_DIM}%s${C_RESET}" "$(fmt_bytes "$size")"
  fi
  printf "\n\n"
}

# ---------- repeat (ping) mode ----------
declare -a STATS_DNS STATS_CON STATS_TLS STATS_PRE STATS_TTFB STATS_TOTAL
OK=0; FAIL=0

print_repeat_header() {
  printf "\n  ${C_BOLD}curltime${C_RESET} ${C_DIM}→${C_RESET} ${C_CYAN}%s${C_RESET}" "$URL"
  if [ "$COUNT" -eq 0 ]; then
    printf "  ${C_DIM}(continuous, interval=%ss — Ctrl+C to stop)${C_RESET}\n" "$INTERVAL"
  else
    printf "  ${C_DIM}(count=%s, interval=%ss)${C_RESET}\n" "$COUNT" "$INTERVAL"
  fi
  printf "  ${C_GREY}────────────────────────────────────────────────────────────${C_RESET}\n"
  printf "  ${C_DIM}%4s  %7s  %7s  %7s  %7s  %9s   %s${C_RESET}\n" "#" "dns" "conn" "tls" "ttfb" "total" "http"
}

print_repeat_row() {
  local i="$1" raw="$2"
  IFS='|' read -r code t_dns t_con t_app t_pre t_ttfb t_total _size _speed _ip <<<"$raw"

  local ms_dns ms_con ms_tls ms_ttfb ms_total
  ms_dns=$(fmt_ms "$t_dns")
  ms_con=$(sub_ms "$t_con" "$t_dns")
  if awk -v a="$t_app" 'BEGIN{exit !(a>0)}'; then
    ms_tls=$(sub_ms "$t_app" "$t_con")
  else
    ms_tls="0.0"
  fi
  ms_ttfb=$(sub_ms "$t_ttfb" "$t_pre")
  ms_total=$(fmt_ms "$t_total")

  STATS_DNS+=("$ms_dns"); STATS_CON+=("$ms_con"); STATS_TLS+=("$ms_tls")
  STATS_TTFB+=("$ms_ttfb"); STATS_TOTAL+=("$ms_total")

  local sc; sc="$(status_color "$code")"
  local tag="${sc}${code:-ERR}${C_RESET}"
  if [ -z "$code" ] || [ "$code" = "000" ]; then
    FAIL=$((FAIL+1))
  else
    OK=$((OK+1))
  fi
  printf "  %4d  %7s  %7s  %7s  %7s  ${C_BOLD}%7s ms${C_RESET}   %b\n" \
    "$i" "$ms_dns" "$ms_con" "$ms_tls" "$ms_ttfb" "$ms_total" "$tag"
}

stats_line() { # stats_line <label> <array...>
  local label="$1"; shift
  awk -v label="$label" 'BEGIN{min=1e18; max=-1; sum=0; n=0}
    {for (i=1;i<=NF;i++){v=$i+0; if(v<min)min=v; if(v>max)max=v; sum+=v; n++}}
    END{ if(n==0){ printf "  %-6s  —\n", label; exit }
         printf "  %-6s  min=%6.1f   avg=%6.1f   max=%6.1f   ms (n=%d)\n",
                label, min, sum/n, max, n }' <<<"$*"
}

print_repeat_summary() {
  printf "  ${C_GREY}────────────────────────────────────────────────────────────${C_RESET}\n"
  printf "  ${C_BOLD}Statistics${C_RESET}   ${C_GREEN}%d ok${C_RESET}   ${C_RED}%d failed${C_RESET}\n" "$OK" "$FAIL"
  stats_line "dns"   "${STATS_DNS[@]:-}"
  stats_line "conn"  "${STATS_CON[@]:-}"
  stats_line "tls"   "${STATS_TLS[@]:-}"
  stats_line "ttfb"  "${STATS_TTFB[@]:-}"
  stats_line "total" "${STATS_TOTAL[@]:-}"
  printf "\n"
}

# ---------- run ----------
run_once() {
  "$CURL_BIN" -s -o /dev/null -w "$WRITE_OUT" "${CURL_ARGS[@]}" 2>/dev/null
  return $?
}

trap 'echo; [ "$COUNT" -ne 1 ] && print_repeat_summary; exit 130' INT

if [ "$COUNT" = "1" ]; then
  raw="$(run_once)"
  rc=$?
  if [ $rc -ne 0 ] || [ -z "$raw" ]; then
    printf "\n  ${C_RED}✗ request failed${C_RESET} ${C_DIM}(curl exit %d)${C_RESET}\n\n" "$rc"
    exit "$rc"
  fi
  print_single "$raw"
else
  print_repeat_header
  i=1
  while :; do
    raw="$(run_once)" || raw="|0|0|0|0|0|0|0|0|"
    print_repeat_row "$i" "$raw"
    [ "$COUNT" -ne 0 ] && [ "$i" -ge "$COUNT" ] && break
    i=$((i+1))
    sleep "$INTERVAL"
  done
  print_repeat_summary
fi
